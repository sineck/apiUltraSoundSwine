# Template only. Runtime/local/Docker tests must use config/.env.
# Copy this file when preparing a new environment, then fill real values there.

# ========================== API ============================================
# Port used by FastAPI and Docker Compose.
MYAPI_PORT=3014

# CORS configuration for browser clients.
# Use comma-separated origins in production, for example: https://app.example.com
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# ========================== MySQL ==========================================
# MySQL connection used by /health and the PDF DB insert step.
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=your_db
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password

# Write switch for PDF conversion results.
# true  = insert converted PDF page results into MySQL.
# false = dry-run conversion/OCR/AI without writing to MySQL.
INSERT_ULTRASOUND_TO_DB=true

# ========================== PDF / YOLO =====================================
# Metadata values saved with each converted PDF page.
cv_code=1
UserID=9

# Minimum YOLO classification confidence. Below this value, result becomes Unknown.
Min_Score_th=0.50

# Model file loaded from the project model/ directory.
ModelName=best_finetune_YOLO26-cls_Ver2_20260424.pt

# Show YOLO result windows during local debugging only. Keep false on servers.
SHOW_YOLO_RESULTS=false

# ========================== Gemini Detection ===============================
# Google Gemini API key and model used by /detect_follicle/.
GEMINI_API_KEY=your-gemini-api-key
MODEL_GEMINI=gemini-3-flash-preview

# Maximum number of images accepted by /detect_follicle/ per request.
Max_Images=5

# Minimum confidence accepted from Gemini detections.
min_score=0.50
